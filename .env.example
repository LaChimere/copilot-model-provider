# Recommended Docker/local auth flow:
#   gh auth login
#   export GITHUB_TOKEN="$(gh auth token)"
# Then pass GITHUB_TOKEN into the container:
#   docker run --rm -e GITHUB_TOKEN -p 8000:8000 copilot-model-provider:local
#
# The service uses Authorization: Bearer ... when a request supplies it.
# Otherwise it falls back to GITHUB_TOKEN (or GH_TOKEN) from the environment.
GITHUB_TOKEN=

# Optional local service settings.
COPILOT_MODEL_PROVIDER_SERVER_HOST=127.0.0.1
COPILOT_MODEL_PROVIDER_SERVER_PORT=8000
